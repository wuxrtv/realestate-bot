# Скопируй этот файл в .env и заполни значения
# На Railway эти переменные вводятся в Dashboard → Variables

# Ключ Claude AI (получить на console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Токен Telegram бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAF...

# База данных — Railway подставляет автоматически при добавлении PostgreSQL
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Название агентства (будет в сообщениях бота)
AGENCY_NAME=НедвижимостьПро

# Имя и телефон агента
AGENT_NAME=Александр
AGENT_PHONE=+79001234567

# Telegram ID агента — узнать через @userinfobot
AGENT_TELEGRAM_ID=123456789

# Railway автоматически задаёт эту переменную — трогать не нужно
# RAILWAY_PUBLIC_DOMAIN=твой-сервис.railway.app
